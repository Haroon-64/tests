fileignoreconfig:
  - filename: uv.lock
    ignore_detectors:
      - filecontent
  - filename: .env.example
    ignore_detectors:
      - filecontent
  - filename: src/app/logger.py
    ignore_detectors:
      - filecontent
  - filename: src/app/config.py
    ignore_detectors:
      - filecontent
version: "1.0"